NEXT_PUBLIC_SITE_URL=https://rezaghobady.com

RESEND_API_KEY=re_your_api_key_here

# Keystatic CMS
# Set to "local" for local dev (no auth required, edits files directly)
# Omit or set to "github" for production (requires GitHub OAuth app)
NEXT_PUBLIC_KEYSTATIC_STORAGE_KIND=local

# Required when KEYSTATIC_STORAGE_KIND=github:
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=          ← random 32-char string, e.g. openssl rand -hex 16
